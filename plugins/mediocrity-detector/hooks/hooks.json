{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "b=\"${CLAUDE_PLUGIN_ROOT}/hooks/bin/mediocrity-detector\"; case \"$(uname -s 2>/dev/null)\" in MINGW*|MSYS*|CYGWIN*|Windows*) exec \"$b.exe\";; Linux) exec \"$b\";; *) exit 0;; esac",
            "commandWindows": "powershell.exe -NoLogo -NoProfile -NonInteractive -Command \"if ([Environment]::GetEnvironmentVariable('PLUGIN_ROOT')) { & (Join-Path ([Environment]::GetEnvironmentVariable('PLUGIN_ROOT')) 'hooks\\bin\\mediocrity-detector.exe') } else { & (Join-Path ([Environment]::GetEnvironmentVariable('CLAUDE_PLUGIN_ROOT')) 'hooks\\bin\\mediocrity-detector.exe') }\""
          }
        ]
      }
    ]
  }
}
