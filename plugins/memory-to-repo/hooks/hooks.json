{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Read|Grep|Glob|ListDir|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "b=\"${CLAUDE_PLUGIN_ROOT}/hooks/bin/memory-to-repo\"; case \"$(uname -s 2>/dev/null)\" in MINGW*|MSYS*|CYGWIN*|Windows*) exec \"$b.exe\" pre-tool-use;; Linux) exec \"$b\" pre-tool-use;; *) exit 0;; esac",
            "commandWindows": "powershell.exe -NoLogo -NoProfile -NonInteractive -Command \"if ([Environment]::GetEnvironmentVariable('PLUGIN_ROOT')) { & (Join-Path ([Environment]::GetEnvironmentVariable('PLUGIN_ROOT')) 'hooks\\bin\\memory-to-repo.exe') pre-tool-use } else { & (Join-Path ([Environment]::GetEnvironmentVariable('CLAUDE_PLUGIN_ROOT')) 'hooks\\bin\\memory-to-repo.exe') pre-tool-use }\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "b=\"${CLAUDE_PLUGIN_ROOT}/hooks/bin/memory-to-repo\"; case \"$(uname -s 2>/dev/null)\" in MINGW*|MSYS*|CYGWIN*|Windows*) exec \"$b.exe\" session-start;; Linux) exec \"$b\" session-start;; *) exit 0;; esac",
            "commandWindows": "powershell.exe -NoLogo -NoProfile -NonInteractive -Command \"if ([Environment]::GetEnvironmentVariable('PLUGIN_ROOT')) { & (Join-Path ([Environment]::GetEnvironmentVariable('PLUGIN_ROOT')) 'hooks\\bin\\memory-to-repo.exe') session-start } else { & (Join-Path ([Environment]::GetEnvironmentVariable('CLAUDE_PLUGIN_ROOT')) 'hooks\\bin\\memory-to-repo.exe') session-start }\""
          }
        ]
      }
    ]
  }
}
