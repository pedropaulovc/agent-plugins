{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "b=\"${CLAUDE_PLUGIN_ROOT}/hooks/bin/powershell-autofix\"; if [ -x \"$b.exe\" ]; then exec \"$b.exe\"; fi; exec \"$b\""
          }
        ]
      }
    ]
  }
}
