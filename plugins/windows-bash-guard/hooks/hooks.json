{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "b=\"${CLAUDE_PLUGIN_ROOT}/hooks/bin/windows-bash-guard\"; if [ -x \"$b.exe\" ]; then exec \"$b.exe\"; fi; exec \"$b\""
          }
        ]
      }
    ]
  }
}
